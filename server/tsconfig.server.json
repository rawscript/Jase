{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "rootDir": "../",
    "baseUrl": "../",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"]
}

// This file is used to configure the TypeScript compiler for the server-side code.