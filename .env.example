# Database Configuration
DATABASE_URL=postgresql://postgres:FX8*M9ys.eDnabv@db.cvbwqzbhgfyorzuxcogd.supabase.co:5432/postgres

# For Supabase (replace with your actual connection string):
# DATABASE_URL=postgresql://postgres.xyz:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Optional: Server Port (defaults to 5000)
PORT=5000

# Environment (development/production)
NODE_ENV=development

# ===========================================
# GMAIL API INTEGRATION
# ===========================================
# 1. Create a Google Cloud Project at: https://console.cloud.google.com/
# 2. Enable Gmail API in APIs & Services > Library
# 3. Create OAuth 2.0 credentials in APIs & Services > Credentials
# 4. Set redirect URI to: http://localhost:5000/api/auth/callback/google (development)
# 5. Add authorized JavaScript origins and redirect URIs for production
# 6. Download credentials and extract the values below

# Gmail OAuth2 Client ID
GMAIL_CLIENT_ID=your_gmail_client_id_here.apps.googleusercontent.com

# Gmail OAuth2 Client Secret
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Gmail OAuth2 Refresh Token
# Generate this by running the OAuth2 flow once in development
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Portfolio owner email (where contact form emails will be sent)
PORTFOLIO_OWNER_EMAIL=jasemwaura@gmail.com

# Gmail API scopes (comma-separated)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/userinfo.email

# ===========================================
# MAP SERVICE CONFIGURATION
# ===========================================
# Choose either Mapbox or Leaflet (Mapbox requires token, Leaflet is open source)

# Option 1: Mapbox GL JS (recommended for better performance)
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Option 2: Leaflet (no token required, uses OpenStreetMap)
# Uncomment to use Leaflet instead of Mapbox
# USE_LEAFLET=true

# Map default viewport (latitude, longitude, zoom)
MAP_DEFAULT_LATITUDE=-1.286389  # Nairobi
MAP_DEFAULT_LONGITUDE=36.817223 # Nairobi
MAP_DEFAULT_ZOOM=10

# Map theme (light/dark)
MAP_THEME=dark

# ===========================================
# LLM SERVICE CONFIGURATION
# ===========================================
# NVIDIA API Configuration (Recommended - DeepSeek V4 Pro)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=16384

# Alternative: OpenAI GPT-4 (Fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Alternative: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-opus-20240229
# ANTHROPIC_MAX_TOKENS=1000
# ANTHROPIC_TEMPERATURE=0.7

# Conversation settings
CONVERSATION_MAX_DEPTH=3
CONVERSATION_TIMEOUT_MS=30000

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Enable/disable features for development
ENABLE_GMAIL_INTEGRATION=true
ENABLE_MAP_VISUALIZATION=true
ENABLE_LLM_CONVERSATION=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_MS=300000  # 5 minutes
ENABLE_RESPONSE_CACHE=true

# ===========================================
# SECURITY SETTINGS
# ===========================================
# CORS configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Session configuration
SESSION_SECRET=your_session_secret_here_change_this
SESSION_MAX_AGE=86400000  # 24 hours

# ===========================================
# CLIENT-SIDE CONFIGURATION (for React app)
# ===========================================
# API URL for frontend
VITE_API_URL=http://localhost:5000

# Feature flags for client
VITE_ENABLE_GMAIL=true
VITE_ENABLE_MAP=true
VITE_ENABLE_LLM=true

# Map configuration for client
VITE_MAPBOX_TOKEN=your_mapbox_access_token_here  # Required for Mapbox
VITE_USE_LEAFLET=false  # Set to true to use Leaflet instead of Mapbox

# ===========================================
# DEVELOPMENT OVERRIDES
# ===========================================
# Use mock services in development
USE_MOCK_GMAIL=false
USE_MOCK_LLM=false

# Development email bypass (for testing without real credentials)
DEV_EMAIL_BYPASS=false
DEV_EMAIL_RECIPIENT=test@example.com

# Debug logging
DEBUG_GMAIL=false
DEBUG_MAP=false
DEBUG_LLM=false
DEBUG_API=false