# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://postgres:FX8*M9ys.eDnabv@db.cvbwqzbhgfyorzuxcogd.supabase.co:5432/postgres

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# CONTACT FORM (GMAIL)
# ===========================================
# To get an app password for Gmail:
# 1. Go to Google Account Manage > Security
# 2. Turn on 2-Step Verification
# 3. Search for "App Passwords"
# 4. Create a new app password for "Mail"
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_character_app_password

# ===========================================
# AI CHAT CONFIGURATION
# ===========================================
# The app supports either NVIDIA NIM (DeepSeek) or OpenAI.
# If both are missing, it falls back to hardcoded responses.

# Option 1: NVIDIA NIM (DeepSeek V3 / R1)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Option 2: OpenAI (GPT-4o mini)
# OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# CLIENT-SIDE CONFIGURATION
# ===========================================
# Set this to your deployed URL in production (e.g., https://your-app.vercel.app)
VITE_API_URL=http://localhost:5000